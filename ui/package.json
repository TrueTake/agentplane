{
  "name": "@getcatalystiq/agent-plane-ui",
  "version": "0.1.0",
  "description": "Embeddable React component library for AgentPlane",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./charts": {
      "import": {
        "types": "./dist/charts.d.ts",
        "default": "./dist/charts.js"
      },
      "require": {
        "types": "./dist/charts.d.cts",
        "default": "./dist/charts.cjs"
      }
    },
    "./editor": {
      "import": {
        "types": "./dist/editor.d.ts",
        "default": "./dist/editor.js"
      },
      "require": {
        "types": "./dist/editor.d.cts",
        "default": "./dist/editor.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "@getcatalystiq/agent-plane": "*",
    "swr": "^2.0.0",
    "react-markdown": "^9.0.0",
    "recharts": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "react-markdown": {
      "optional": true
    },
    "recharts": {
      "optional": true
    }
  },
  "dependencies": {
    "@radix-ui/react-popover": "^1.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "cmdk": "^1.0.0",
    "tailwind-merge": "^2.0.0"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "swr": "^2.0.0",
    "tsup": "^8",
    "typescript": "^5"
  },
  "keywords": [
    "agent-plane",
    "agentplane",
    "react",
    "components",
    "ui",
    "ai-agents",
    "embeddable",
    "admin-panel"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/getcatalystiq/agent-plane.git",
    "directory": "ui"
  }
}
